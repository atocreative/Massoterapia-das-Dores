{
  "project": "Massoterapia das Dores",
  "stack": "Next.js 16.2.9 + Tailwind CSS v4 + TypeScript",
  "deploy_target": "Railway",
  "palette": {
    "primary": "#99d252",
    "primary_dark": "#7ab83e",
    "auxiliary_light": "#f0f4c3",
    "dark": "#1a2e0f",
    "dark_mid": "#2d5016",
    "text": "#333333",
    "white": "#ffffff"
  },
  "typography": {
    "serif": "Playfair Display (headlines H1, H2)",
    "sans": "Inter (body, UI, labels)"
  },
  "sections": [
    "navbar",
    "hero",
    "sobre",
    "servicos",
    "cinematic-cta",
    "contato",
    "footer"
  ],
  "section_chapters": [
    {
      "name": "Abertura",
      "sections": ["navbar", "hero"],
      "bg": "dark green overlay on photo"
    },
    {
      "name": "Autoridade",
      "sections": ["sobre"],
      "bg": "#f0f4c3 cream-green"
    },
    {
      "name": "Serviços",
      "sections": ["servicos"],
      "bg": "#1a2e0f deep forest"
    },
    {
      "name": "Conversão",
      "sections": ["cinematic-cta"],
      "bg": "photo with overlay"
    },
    {
      "name": "Contato",
      "sections": ["contato", "footer"],
      "bg": "#ffffff + #1a2e0f"
    }
  ],
  "connectors": [
    "Hero → Sobre: diagonal clip-path (polygon bottom)",
    "Sobre → Serviços: SVG wave divider",
    "Serviços → CTA: overlap with padding",
    "CTA → Contato: diagonal reverse",
    "Contato → Footer: color transition"
  ],
  "hero": {
    "archetype": "cinematic_centered",
    "h1": "Conquiste bem-estar e alivie dores com profissionais especializados",
    "target_words": ["alivie", "bem-estar"],
    "emphasis": "accent_color (#99d252) + italic for 'alivie'",
    "cta": "Agendar pelo WhatsApp",
    "visual": "Pexels massage photo with green gradient overlay",
    "kicker_above_h1": false
  },
  "logo": {
    "type": "symbol_only",
    "description": "Árvore da vida, silhueta escura",
    "lockup": "symbol + wordmark text",
    "wordmark": "Massoterapia das Dores"
  }
}
